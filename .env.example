# ── LiveKit Cloud ──────────────────────────────────────────────────────────────
# Create a free project at https://cloud.livekit.io → Settings → Keys.
# STT/LLM/TTS all route through LiveKit Inference using these credentials —
# no separate OpenAI / Deepgram / Cartesia accounts needed to run the agent.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Evals only (optional) ────────────────────────────────────────────────────
# The pytest eval harness calls the LLM directly. Set this only if you run evals.
# OPENAI_API_KEY=sk-...
